<?xml version="1.0"?>
<ruleset name="test-dogfood"
    xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 http://pmd.sourceforge.net/ruleset_2_0_0.xsd">
    <description>Rules to check PMD's test code</description>

    <rule ref="category/java/bestpractices.xml/LiteralsFirstInComparisons">
        <priority>1</priority>
    </rule>
    <rule ref="category/java/bestpractices.xml/JUnit5TestShouldBePackagePrivate">
        <priority>1</priority>
    </rule>

    <rule name="RuleTestsShouldBeEmpty"
          language="java"
          since="7.17.0"
          message="Rule tests should be empty for now"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>Detects classes that extend net.sourceforge.pmd.test.PmdRuleTst</description>
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
                    <![CDATA[
//ClassDeclaration[ExtendsList/ClassType[pmd-java:typeIs('net.sourceforge.pmd.test.PmdRuleTst')]]
    [ClassBody/*[not(self::Comment)]]
]]>
                </value>
            </property>
        </properties>
    </rule>
</ruleset>
